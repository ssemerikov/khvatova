	pages = {191 - 205},
	doi = {10.15390/EB.2020.9154},
	url = {https://www.scopus.com/pages/publications/85108106039?origin=resultslist},
	abstract = {By using certain techniques, teachers can set an example to their students that fosters development of their creative thinking abilities in addition to other attitudes and behaviors. The general objective of this study, conducted at the primary school level, was to analyze the effects of personality traits of teachers on the development of creative-thinking abilities among students. The Adjective-Based Personality Scale, an in-class observation form, and a creativity task were employed as data collection instruments. At the end of the study, it was found that the teachers with high levels of the openness to experience personality trait exhibited significantly higher levels of behavior supportive of in-class creativity and that the creativity scores of the students in their classes were significantly high. No significant differentiation was found in comparisons related to the personality traits of agreeableness and neuroticism. © 2021 Turkish Education Association. All rights reserved.},
	author_keywords = {Classroom teacher; Creative-thinking; Creativity-fostering behavior; Openness to experience; Personality traits},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3; All Open Access; Gold Open Access; Green Open Access}
}

