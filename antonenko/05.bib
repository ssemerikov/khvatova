@ARTICLE{Pivac2020143,
	author = {Pivac, Dunja and Zemunik, Maja},
	title = {The self-portrait as a means of self-investigation, self-projection and identification among the primary school population in croatia; [Avtoportret kot sredstvo samoraziskovanja, samoprojekcije in identifikacije med osnovnošolsko populacijo na hrvaškem]},
	year = {2020},
	journal = {Center for Educational Policy Studies Journal},
