	pages = {124 - 127},
	url = {https://www.scopus.com/pages/publications/0019120168?origin=resultslist},
	abstract = {The essential aim of motor re-education is not the development of a complex and specialised movement, but the mastery of the ductility and of the motor originality. The complexity and specialisation are not necessarily higher in man than in animals but the ductility and the originality of movement are essential attributes that make man - and only man - free and creative. Psychomotor therapy favors an interiorised mental reconstruction of new schemes, new sequences new behaviors that are the projection of needs that, always more personal, are subordinated to ends that are always more complex. The child receives efficacious stimulations in the following directions: he feels encouraged to displace his need in order to explore, construct, communicate and to know. He draws his experience not from obligatory sequences, but from plastic schemes that have to be remounted and synthetised variously. He is stimulated not towards a rigid, cold, rational motor programmation, but towards a motor projection of the whole of the personality in its conscious or unconscious aspects. Thus he is encouraged to withdraw the immediate control of the Ego in the behavior to renounce allowing manifestation of the pre-consciousness, that is to say, the totality of the personal life that has already been experienced. This latter aspect is the condition and the essential attribute of the creativity, which in a psychomotor therapy or in therapy of any kind, constitutes the sure confirmation of success.},
	keywords = {central nervous system; learning disorder; liaison psychiatry; psychomotor education; school child; therapy},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Savina202072,
	author = {Savina, Elena G.},
	title = {ON THE ISSUE OF FORMING ABILITIES OF INTERPERSONAL INTERACTION OF STUDENTS UNDER THE CONDITIONS OF MUSICAL-THEATER ACTIVITY; [К ВОПРОСУ О ФОРМИРОВАНИИ УМЕНИЙ МЕЖЛИЧНОСТНОГО ВЗАИМОДЕЙСТВИЯ ОБУЧАЮЩИХСЯ В УСЛОВИЯХ МУЗЫКАЛЬНО-ТЕАТРАЛЬНОЙ ДЕЯТЕЛЬНОСТИ]},
	year = {2020},
	journal = {Musical Art and Education},
	volume = {8},
	number = {2},
	pages = {72 - 86},
	doi = {10.31862/2309-1428-2020-8-2-72-86},
	url = {https://www.scopus.com/pages/publications/85104079449?origin=resultslist},
	abstract = {Interpersonal interactions of people in society not only regulate the processes of communication, but also have a significant impact on the formation of their personality traits. It is for this reason that the problems associated with interpersonal interaction do not lose their relevance, and the process of forming their skills in various aspects is studied by scientists and practitioners in the field of psychology and pedagogy. The first active and conscious interpersonal interaction skills begin to form in older preschool and primary school ages. This is due to the flexibility of perception, exceptional sensitivity to the emotional context and artistic creativity. However, older students at a new level of development of their affective and cognitive functions also encounter difficulties in interpersonal communication. The process of development and restructuring of interpersonal interaction skills lasts a lifetime. As is highlighted in the article, these skills are updated in a new way within the framework of university education, including in the preparation of future young teachers for organizing communication between schoolchildren. This article discusses the possibilities and functions of musical and theatrical activities of students at different levels of education as a contribution to the formation of baggage of interpersonal interaction skills, reveals the psychological mechanisms of their implementation in educational musical theater. A review of modern research aimed at studying the educational and developmental potential of musical and theatrical activities of children is presented, discussion questions are raised on organizing interpersonal interaction in the face of the challenges of the digital era, prompting the search for new forms in musical education in general and in musical and theatrical activities students. © 2020. All rights reserved},
	author_keywords = {constructive peer communication; experimental and pedagogical space of musical theater; musical and theatrical activities; perceptual mechanisms of percept; skills of interpersonal interaction},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Zhang20182999,
