@ARTICLE{Erkkilä1997112,
	author = {Erkkilä, Jaakko},
	title = {From the unconscious to the conscious},
	year = {1997},
	journal = {Nordisk Tidsskrift for Musikkterapi},
	volume = {6},
	number = {2},
	pages = {112 - 120},
	doi = {10.1080/08098139709477904},
	url = {https://www.scopus.com/pages/publications/85009633783?origin=resultslist},
	abstract = {In my clinical experience as a music therapist, I have observed that the ambiguous character of music makes it necessary to have a wide and flexible view as to the psychological frame of reference in the background of music therapy. With the help of the three-dimensional model that I have formulated, it is possible to take into account the different musical meanings in the therapeutical process with a wider view. The three-dimensional model is composed of three levels specifying musical meanings: The vitality affect level, the psycho-dynamic level, and the cognitive level. In fitting together these levels of meaning, recent research findings in the developmental psychology - mainly according to Daniel Stern (1985) -, the brain dominance theory as well as the psychoanalytical theory on reformulating the primary and secondary process thinking - Eva Basch-Kahre (1985) - are utilized. In this article I also deal with a case study of the music therapy process of an eleven-year-old boy suffering from language disorders. The main methods used in the therapy process were clinical improvisation, drawing, and cog- nitive-motoric rhythm and melody exercises. The therapy process shows that the holistic approach that takes into account not only the cognitive-motoric exercises (cognitive meaning level) but also creative self-expression (psycho-dynamic meaning level and vitality affect level) was justified. © 1997, Taylor & Francis Group, LLC. All rights reserved.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 12}
}

