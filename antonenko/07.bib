@ARTICLE{Lokon2019471,
	author = {Lokon, Elizabeth and Sauer, Philip E and Li, Yue},
	title = {Activities in dementia care: A comparative assessment of activity types},
	year = {2019},
	journal = {Dementia},
	volume = {18},
	number = {2},
	pages = {471 - 489},
	doi = {10.1177/1471301216680890},
	url = {https://www.scopus.com/pages/publications/85058963265?origin=resultslist},
	abstract = {This exploratory study compares the impact of five activity types on the well-being of institutionalized people with dementia: the intergenerational art program Opening Minds through Art, art and music therapies, creative activities, non-creative activities, and no activities at all. We validated the Scripps Modified Greater Cincinnati Chapter Well-Being Observational Tool, and used that instrument to systematically observe N = 67 people with dementia as they participated in different activity types. People with dementia showed the highest well-being scores during Opening Minds through Art compared to all other activities. No significant well-being differences were found between creative activities led by licensed art/music therapist versus regular activity staff. Furthermore, no significant well-being differences were found between creative and non-creative activities that were both led by regular activity staff. Overall, people with dementia benefit from participating in activities, regardless of the type (creative or non-creative), or who conducts them (licensed therapists or activity staff). However, in order for people with dementia to reach significantly high levels of overall well-being, we recommend that activities are specifically designed for people with dementia and incorporate a 1:1 ratio between people with dementia and well-trained volunteers/staff members. © The Author(s) 2016.},
	author_keywords = {Alzheimer’s disease; comparative assessment; creative self-expression; dementia activities; well-being},
	keywords = {Art Therapy; Dementia; Female; Humans; Male; Music Therapy; Psychiatric Status Rating Scales; Quality of Life; Treatment Outcome; art therapy; dementia; female; human; male; music therapy; psychological rating scale; psychology; quality of life; standards; treatment outcome},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 21}
}

@ARTICLE{Khalifa2026,
	author = {Khalifa, Giana and Massarwa, Zakiah and Krayem, Marwa and Hosni, Layan},
