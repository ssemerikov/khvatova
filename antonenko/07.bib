	pages = {},
	doi = {10.1080/07421656.2026.2622757},
	url = {https://www.scopus.com/pages/publications/105032409485?origin=resultslist},
	abstract = {Art therapy is increasingly used in early childhood education to support children’s emotional, social, and psychological development; however, kindergarten teachers’ perspectives remain underexplored. This qualitative study examines teachers’ views on the application and impact of art therapy for children aged 3–6 in Arabic-language public kindergartens serving Arab citizens of Israel. Fifteen teachers with direct experience in art therapy programs were purposively selected. Data were collected through semi-structured interviews and analyzed using consensual qualitative research and thematic analysis. Findings indicate that art therapy enhances emotional regulation, self-expression, communication skills, and self-confidence. Teachers also reported challenges related to training, coordination, time allocation, and resources, and suggested strategies to improve implementation and sustainability within contemporary inclusive early childhood educational settings globally. © AATA, Inc. 2026.},
	author_keywords = {Art therapy; creative Self-Expression; early childhood; kindergarten; kindergarten teachers; psychotherapy},
	keywords = {Arabic (language); art; art therapy; article; child; childhood; clinical article; communication skill; controlled study; emotion regulation; emotional development; female; human; Israeli; kindergarten; male; preschool child; psychological development; psychotherapy; qualitative research; role playing; self concept; semi structured interview; teacher; thematic analysis; therapy},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Romadlon2025624,
	author = {Romadlon, Farid Noor and Setiawan, Slamet and Anam, Syafi’Ul},
	title = {Speaking E-Portfolios and Non-EFL Students’ Well-Being: Evidence from Indonesian Higher Education},
	year = {2025},
	journal = {Journal of Learning for Development},
	volume = {12},
	number = {3},
	pages = {624 - 635},
	doi = {10.56059/jl4d.v12i3.1625},
	url = {https://www.scopus.com/pages/publications/105024096880?origin=resultslist},
	abstract = {This study examines the role of speaking e-portfolios in enhancing the well-being of non-English-major university students in Indonesia. The research was motivated by the growing need to integrate digital learning tools that not only support language proficiency but also promote students’ overall well-being in higher education. A mixed-method design was employed with 66 undergraduate students from Central Java. Quantitative data were collected using the Student Well-Being Model (SWBM) questionnaire, while qualitative insights were obtained through semi-structured interviews with nine participants. The statistical results indicated a high level of student well-being, with an overall mean score of 74.48. Across the SWBM dimensions, students reported strong Assets (76.5), positive Appraisals (78.8), and supportive Actions (68.15). The interview data reinforced these findings, revealing that students perceived e-portfolios as beneficial for sustained engagement with speaking activities, increased digital connectivity with classroom tasks, and opportunities for creative self-expression. The participants highlighted that regular e-portfolio use provided them with greater exposure to authentic speaking practice and encouraged consistent reflection on their progress. The study concludes that speaking e-portfolios can be an effective pedagogical strategy not only for improving speaking competence but also for fostering non-EFL students’ well-being in higher education. Practical implications are offered for educators seeking to integrate digital portfolios into language learning to promote both skill development and psychological well-being. © 2025, Commonwealth of Learning. All rights reserved.},
	author_keywords = {higher education; non-EFL learners; speaking e-portfolios; student well-being},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Aksenov2025,
	author = {Aksenov, Vladislav},
	title = {Art and the Artist During the Great Patriotic War: Propaganda, Creativity, Therapy},
	year = {2025},
	journal = {Istoriya},
	volume = {16},
	number = {2},
	pages = {},
	doi = {10.18254/S207987840034828-9},
	url = {https://www.scopus.com/pages/publications/105009418957?origin=resultslist},
	abstract = {The article studies the reflection of the Great Patriotic War era in the art of that time. The author examines the manifestation of the main functions of art — aesthetic, propaganda and psychotherapeutic — based on the works themselves, the statements of their authors and consumers, and the authorities' official attitudes. The article concludes that the general situation during the Great Patriotic War did not favor the creative self-expression of the artistic intelligentsia. Among the immediate reasons are both the traumatic experience of wartime everyday life, which created psychological barriers, and censorship ideological restrictions and propaganda, which excluded some themes and imposed others on artists. The enormous mobilizing effect of art during the war, as stated by Soviet historiography, can be considered exaggerated, given the known cases of opposition to it on the part of some of the artistic intelligentsia and the public’s rejection of certain “program” works. Nevertheless, art continued to fulfill other important functions, satisfying the aesthetic needs of the individual and offering therapeutic ways of accepting traumatic experiences. In the conditions of deep moral crisis caused by the war, dehumanization of the sphere of interpersonal relations, art maintained moral and ethical guidelines that allowed to hope for the preservation and restoration of the cultural foundations of society after the victory, as well. © 2025, Ltd "Integration: Education and Science". All rights reserved.},
	author_keywords = {aesthetics; art; list (en): Great Patriotic War; propaganda; psychotherapy; Stalinism},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Dowlen2024,
	author = {Dowlen, Robyn and McPherson, Dougal Henry James and Swarbrick, Caroline and Hoskin, Lizzie and Thompson, James and Keady, John},
	title = {Creating and Reliving the Moment: Using Musical Improvisation and Care Aesthetics as a Lens of Connection and Self-Expression for Younger People Living with Dementia},
	year = {2024},
	journal = {International Journal of Environmental Research and Public Health},
	volume = {21},
	number = {8},
	pages = {},
	doi = {10.3390/ijerph21080972},
	url = {https://www.scopus.com/pages/publications/85202592923?origin=resultslist},
	abstract = {Musical improvisation is a generative process of spontaneously creating music ‘in the moment’. For people with young onset dementia, musical improvisation provides an extended opportunity for creative self-expression and connection to one’s own body and life story. Using visual research methods, including video elicitation interviews, this paper explores the ‘in the moment’ musical experiences of five people living with young onset dementia who took part in a 15-week improvised music-making programme (Music in Mind). We frame the exploration of the group’s musical experiences through the emerging lens of ‘care aesthetics’—a concept that identifies the sensory relations and embodied practices between two (or more) people in a caring relationship. In the context of this analysis, we look to the caring practices by, with, and between people living with dementia, their family members, and the musicians who lead the programme and the relationship of these practices to feelings of self-expression and meaningful connection. Musical improvisation has the potential to support the psychological, social, and spiritual wellbeing of people living with young onset dementia. In applying a lens of care aesthetics, it is possible to observe the micro-level experiences of people living with dementia and their family carers. © 2024 by the authors.},
	author_keywords = {care aesthetics; group music-making; musical improvisation; visual methods; young onset dementia; ‘in the moment’},
	keywords = {Adult; Caregivers; Dementia; Esthetics; Female; Humans; Male; Middle Aged; Music; anesthetic agent; mental disorder; mental health; music; public health; visual analysis; adult; Alzheimer disease; anesthesia; Article; care behavior; caregiver; decision making; dementia; esthetics; human; music; musician; scientific literature; spiritual well-being; videorecording; young adult; female; male; middle aged; psychology; therapy},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 6; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Hunt20141139,
	author = {Hunt, Laura and Nikopoulou-Smyrni, Panagiota and Reynolds, Frances},
	title = {"It gave me something big in my life to wonder and think about which took over the space ⋯ and not MS": Managing well-being in multiple sclerosis through art-making},
	year = {2014},
	journal = {Disability and Rehabilitation},
	volume = {36},
	number = {14},
	pages = {1139 - 1147},
	doi = {10.3109/09638288.2013.833303},
	url = {https://www.scopus.com/pages/publications/84903301037?origin=resultslist},
	abstract = {Background and aim: Individuals living with Multiple Sclerosis (MS) often face progressive loss of function, uncertainty and disruption to self-image and valued roles. Previous studies show that creative self-expression is valued by some people living with long-term illness, yet its meaning for people living with MS is unclear. This research study explored the meanings of leisure-based visual art-making for people living with MS. Method: This qualitative study followed guidelines for Interpretative Phenomenological Analysis (IPA). Single semi-structured interviews were conducted with five adults (2 males; 3 females; 40-65 years), recruited from MS Ireland. Findings: Participants valued art-making for contributing to a more satisfying way of life; for filling occupational voids and using time well. Deep immersion offered respite from worry about illness. Creative classes offered social camaraderie and opportunities for learning and development. Art-making processes and products were highly affirmative, increasing emotional well-being and promoting self-worth. Most felt that they expressed valued aspects of self through their art. Art-making appeared to assist with identity maintenance, accommodating functional losses associated with MS whilst opening "new doors". Conclusion: Art-making offered a multi-faceted means of supporting identity and increasing fulfilment in lives that were restricted in many ways by MS. © 2014 Informa UK Ltd.},
	author_keywords = {Art; Creativity; Flow; Multiple sclerosis; Occupation; Self-esteem; Well-being},
	keywords = {Adaptation, Psychological; Adult; Aged; Art; Art Therapy; Chronic Disease; Disabled Persons; Female; Humans; Interview, Psychological; Ireland; Male; Middle Aged; Multiple Sclerosis; Qualitative Research; Quality of Life; Self Concept; adaptive behavior; adult; aged; art; art therapy; chronic disease; disabled person; female; human; Ireland; male; middle aged; multiple sclerosis; procedures; psychologic test; psychology; qualitative research; quality of life; self concept},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 16; All Open Access; Green Open Access}
}

@ARTICLE{Zobkov2021329,
	author = {Zobkov, Alexander V. and Vasilievna, Plaksina Irina},
	title = {Formation of an innovation-pedagogical actor in the school environment; [Становление субъекта инновационной педагогической деятельности в условиях школы]},
	year = {2021},
	journal = {Perspektivy Nauki i Obrazovania},
	volume = {51},
	number = {3},
	pages = {329 - 343},
	doi = {10.32744/pse.2021.3.23},
	url = {https://www.scopus.com/pages/publications/85109275298?origin=resultslist},
	abstract = {Introduction. The need to develop and test a complex of psychological-pedagogical tools for the development of an innovation actor is due to the priorities of the national policy in the field of education, as well as the requirements for the teacher’s competencies in innovation, enshrined in the Professional Standard “Teacher”. Research purpose: the testing of a set of psychological-pedagogical tools for the development of an innovation actor, corresponding to the eco-psychological actor formation model. Materials and methods: during the 2017/2019 academic years, 78 students from schools in the city of Vladimir (Russian Federation) took part in the experimental verification of the eco-psychological model of innovation-pedagogical actor development. On diagnostic sections in the process of tools testing, the following methods were used: a method of determining the degree of manifestation of the organizational-educational models by V.A. Yasvin’s school, A.V. Kaptsov’s method to determine the degree of subjectivity manifestation at each stage of the eco-psychological model, a questionnaire “Personal Characteristics of a Professional” by I.G. Senin and V.E. Oryol, a test “Tolerance to Uncertainty” by D.А. Leontyev, a questionnaire “Creativity” by N.F. Vishnyakova. Research results. The set of psychological-pedagogical tools includes events (workshops, trainings, round tables) aimed at the formation of pedagogical subjectivity in accordance with the staging of the eco-psychological model (from an actor of perceptual activity to an actor of creative self-expression) and the organizational-modular organization of the educational space. The presented results reflect the positive dynamics of manifestation of subjectivity stages: “Master” (p<0.05), “Creator” (p<0.01) in the experimental sample, as well as a change in the manifestation of the innovation-modular organizational-educational model of the experimental school (U<sub>(26.40)</sub>=336.0, p=0.016). Differences (p<0.05) were found in favor of the experimental school in terms of parameters characterizing creative thinking, open-mindedness, tolerance to uncertainty. It is shown that the eco-psychological model of innovation-pedagogical actor development is effective in the experimental school environment and allows for a systematic analysis of the current state and readiness of an educational organization for innovative changes. The developed set of psychological-pedagogical tools is the basis for the subsequent development of a system of scientific-methodological support of a school team as an innovation-pedagogical group actor. © 2021 LLC Ecological Help. All rights reserved.},
	author_keywords = {Actor; Actor formation; Eco-psychological approach; Innovation-pedagogical activity; Organizational-educational model; Subjective qualities; Subjectivity development},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
}

