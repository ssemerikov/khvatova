}

@ARTICLE{Chomaeva2021205,
	author = {Chomaeva, Gokkajan A. and Semenova, Faizura O. and Laipanova, Zulfa M. and Laipanova, Fatima H. and Kubanova, Marina N.},
	title = {The Development of Giftedness as a Necessary Condition for the Formation of the Subject of Socio-economic Systems of Our Time},
	year = {2021},
	journal = {Lecture Notes in Networks and Systems},
	volume = {198},
	pages = {205 - 215},
	doi = {10.1007/978-3-030-69415-9_24},
	url = {https://www.scopus.com/pages/publications/85108505247?origin=resultslist},
	abstract = {Purpose: the article consists in the analysis of the problem of diagnosis and development of giftedness as the most important condition for the growth of the intellectual and creative potential of modern Russian society and the search for the most effective methods for the development of giftedness as a necessary condition for the formation of the subject of socio-economic systems of our time. Methodology: retrospective analysis of the main approaches to the study of giftedness, its models developed by foreign and domestic scientists; system-synergistic methodology as the most effective approach to the development of a gifted person. The article describes the practical activities of the employees of the Center for the Identification and Support of Gifted Children “Talent and Success” of Karachay-Cherkess State University named after U.D. Aliyev. The work is carried out within the framework of the functioning of schools of intensive intellectual development for children of primary school age and adolescents. The main forms of organizing work along with classrooms are training, intellectual and business games, competitions. Result: it has been shown that the use of a systemic synergistic approach allows us to re-prioritize educational activities, in which the ability of a gifted person to self-work and self-development becomes the main one. The results of the work carried out with schoolchildren indicate the effectiveness of the chosen approach. Students acquired skills in communication and professional self-determination, presentation of the results of scientific research; learned to define the goals and objectives of their activities, comparing them with a system of values. The results of diagnostics according to the methodology of P. Torrens before and after studying at the school for the development of creative thinking showed significant changes in the level of creativity of students. © 2021, Springer Nature Switzerland AG.},
	author_keywords = {Bifurcation; Creativity; Creativity; Development of endowments; Endowments; Endowments models; Genius; Intellectual endowments; Sensitive period; Subject of activity; System and synergetic approach; Theories of endowments},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

