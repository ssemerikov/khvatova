@ARTICLE{Lasta202572,
	author = {Lasta, Isadora Casal Dalla and Oliveira, Eduarda Luiza Freitas and de Oliveira, Thainá Sanhudo and Feijó, Luan Paris and Pato, Claudia Marcia Lyra and de Campos, Camila Bolzan},
	title = {Nature connectedness in students and teachers from public elementary schools in Canoas, Brazil; [Conexão com a natureza em estudantes e docentes de escolas municipais de educação básica em Canoas, Brasil]; [Conexión con la naturaleza en estudiantes y docentes de escuelas públicas de educación primaria en Canoas, Brasil]},
