@ARTICLE{Marković201978,
	author = {Marković, Marijana Kokanović},
	title = {The phenomenon of the 19th century music migrations in the case of artistic and pedagogical activities of robert tollinger (1859–1911); [Fenomén hudební migrace na příkladu umělecké a pedagogické činnosti roberta tollingera (1859–1911)]},
